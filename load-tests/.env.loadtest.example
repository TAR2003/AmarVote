# Copy to load-tests/.env.loadtest and fill in values (never commit .env.loadtest)
# Or rely on the project root .env — run.sh loads both automatically.

# Cloud server (production load tests):
BASE_URL=https://amarvote2026.me

# Local docker-compose (nginx on :80; backend :8080 is internal-only):
# BASE_URL=http://localhost

# Same value as project root .env (local) or server ~/.env (cloud):
#   ssh <user>@amarvote2026.me "grep ^JWT_SECRET= ~/.env"
# run.sh maps JWT_SECRET -> JWT_SECRET_B64 for k6
JWT_SECRET=

# Must match backend application.properties jwt.expiration (milliseconds)
JWT_EXPIRATION_MS=3600000

# Election under test — candidate names are fetched from GET /api/election/:id at runtime
ELECTION_ID=10

# Synthetic voter emails: loadtest-voter-0001@yourdomain.com … loadtest-voter-2000@yourdomain.com
TEST_EMAIL_PREFIX=loadtest-voter
TEST_EMAIL_DOMAIN=yourdomain.com

# Peak virtual users (final step in the ramp)
MAX_VUS=2000

# Stepped ramp profile — ramp to each level, hold, then increase (industrial soak testing)
# Default steps: 50 → 100 → 200 → 500 → 1000 → MAX_VUS
VU_STEPS=50,100,200,500,1000
STAGE_RAMP_DURATION=2m
STAGE_HOLD_DURATION=3m
RAMP_DOWN_DURATION=5m

# vote-encrypt-sequential.js — fixed vote count with optional concurrency
SEQ_CONCURRENT_VUS=1
SEQ_TOTAL_VOTES=200
# SEQ_PAUSE_MS=0
# TEST_EMAIL_START_OFFSET=0

# realistic-vote.js / realistic-vote-sequential.js — user behaviour mix
# Set ENCRYPT_WARMUP_ITERS=0 for accurate email reservation in stepped realistic runs
REALISTIC_BROWSE_ONLY_PCT=15
REALISTIC_ELIGIBILITY_ONLY_PCT=10
REALISTIC_EXTRA_ENCRYPT_PCT=20
REALISTIC_EXTRA_ENCRYPT_MAX=2
REALISTIC_INCLUDE_SESSION=1
REALISTIC_THINK_MIN_MS=300
REALISTIC_THINK_MAX_MS=2500
REALISTIC_BROWSE_DETAIL_PCT=85
